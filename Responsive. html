<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Startup Landing Page</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial;
        }

        body {
            line-height: 1.6;
        }

        header {
            background: #333;
            color: white;
            padding: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        header h1 {
            font-size: 22px;
        }

        nav a {
            color: white;
            margin: 0 10px;
            text-decoration: none;
        }

        .hero {
            background: #f4f4f4;
            padding: 50px;
            text-align: center;
        }

        .hero h2 {
            margin-bottom: 10px;
        }

        .btn {
            display: inline-block;
            background: #333;
            color: white;
            padding: 10px 20px;
            margin-top: 10px;
            text-decoration: none;
        }

        .features {
            display: flex;
            flex-wrap: wrap;
            padding: 20px;
            text-align: center;
        }

        .feature {
            flex: 1;
            padding: 20px;
        }

        .testimonials {
            background: #eee;
            padding: 20px;
            text-align: center;
        }

        footer {
            background: #333;
            color: white;
            text-align: center;
            padding: 10px;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .features {
                flex-direction: column;
            }
        }
    </style>
</head>
<body>

<header>
    <h1>My Startup</h1>
    <nav>
        <a href="#">Home</a>
        <a href="#">Features</a>
        <a href="#">Contact</a>
    </nav>
</header>

<section class="hero">
    <h2>Welcome to Our Product</h2>
    <p>We provide amazing solutions for your business.</p>
    <a href="#" class="btn">Get Started</a>
</section>

<section class="features">
    <div class="feature">
        <h3>Feature 1</h3>
        <p>High quality service</p>
    </div>
    <div class="feature">
        <h3>Feature 2</h3>
        <p>Fast performance</p>
    </div>
    <div class="feature">
        <h3>Feature 3</h3>
        <p>24/7 Support</p>
    </div>
</section>

<section class="testimonials">
    <h3>What our users say</h3>
    <p>"This product is amazing!"</p>
</section>

<footer>
    <p>© 2026 My Startup</p>
</footer>

</body>
</html>
